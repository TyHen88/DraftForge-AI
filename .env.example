# Telegram
TELEGRAM_BOT_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SYSTEM_ROLE=system

# Behavior / Limits
MAX_INPUT_CHARS=8000
MAX_OUTPUT_TOKENS=800
TEMPERATURE=0.7

# Rate limiting (per user)
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Networking
OPENAI_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO

# Mini App HTTP API (only used by `serve`; the polling bot ignores these)
API_HOST=0.0.0.0
# Railway injects PORT automatically; API_PORT is the local fallback.
API_PORT=8000
# CORS: the frontend origin(s), comma-separated (e.g. https://<user>.github.io). "*" for dev.
FRONTEND_ORIGIN=*
# SQLite file for persisted per-user preferences.
DB_PATH=writer_ai.db
# Reject initData older than this many seconds (default 24h).
INITDATA_MAX_AGE_SECONDS=86400
# Public HTTPS URL of the Mini App. When set, the bot's menu button becomes "Open App".
WEBAPP_URL=https://draft-forge.encode54.workers.dev
